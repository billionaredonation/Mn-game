:root {
  --bg-1: #0b1020;
  --bg-2: #111827;
  --bg-3: #1f2937;
  --text: #f8fafc;
  --muted: #cbd5e1;
  --line: rgba(255, 255, 255, 0.12);
  --shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  --radius-xl: 28px;
  --radius-lg: 20px;
  --success: #bbf7d0;
  --error: #fecaca;
}

* {
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

html,
body {
  margin: 0;
  padding: 0;
  min-height: 100%;
  font-family: Arial, sans-serif;
  color: var(--text);
  background:
    radial-gradient(circle at top left, #25314f 0%, transparent 35%),
    radial-gradient(circle at bottom right, #1d3f5c 0%, transparent 35%),
    linear-gradient(160deg, var(--bg-1), var(--bg-2), var(--bg-3));
}

body {
  min-height: 100vh;
  overflow: hidden;
}

button,
input {
  font: inherit;
}

.app-shell {
  position: relative;
  min-height: 100vh;
  padding: 20px 16px 28px;
  display: flex;
  flex-direction: column;
}

.topbar {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: center;
  padding-top: 12px;
  margin-bottom: 18px;
}

.logo {
  font-size: 42px;
  font-weight: 900;
  letter-spacing: 2px;
  text-shadow: 0 8px 30px rgba(255, 255, 255, 0.25);
}

#app {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-orb {
  position: absolute;
  border-radius: 999px;
  filter: blur(60px);
  opacity: 0.45;
  pointer-events: none;
}

.orb-1 {
  width: 220px;
  height: 220px;
  top: -60px;
  left: -80px;
  background: rgba(59, 130, 246, 0.35);
}

.orb-2 {
  width: 240px;
  height: 240px;
  right: -90px;
  bottom: -80px;
  background: rgba(255, 255, 255, 0.16);
}

.screen-card {
  width: 100%;
  max-width: 420px;
  border-radius: var(--radius-xl);
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.15),
    rgba(255, 255, 255, 0.06)
  );
  border: 1px solid var(--line);
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  padding: 28px 22px;
  animation: fadeIn 0.35s ease;
}

.eyebrow {
  margin: 0 0 10px;
  font-size: 12px;
  letter-spacing: 3px;
  color: var(--muted);
}

h1,
h2 {
  margin: 0;
  line-height: 1.08;
}

h1 {
  font-size: 34px;
  margin-bottom: 14px;
}

h2 {
  font-size: 30px;
  margin-bottom: 10px;
}

.text-muted,
.subtext,
.hint {
  color: var(--muted);
}

.subtext {
  font-size: 15px;
  line-height: 1.55;
  margin: 0 0 24px;
}

.hint {
  font-size: 13px;
  margin: 0 0 20px;
}

.hint.error {
  color: var(--error);
}

.hint.success {
  color: var(--success);
}

.primary-btn {
  width: 100%;
  height: 56px;
  border: none;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #ffffff, #dbeafe);
  color: #0f172a;
  font-size: 17px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.18s ease, opacity 0.18s ease;
  box-shadow: 0 12px 24px rgba(255, 255, 255, 0.15);
}

.primary-btn:active {
  transform: scale(0.98);
}

.text-input {
  width: 100%;
  height: 56px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-lg);
  outline: none;
  padding: 0 16px;
  color: var(--text);
  font-size: 16px;
  margin-bottom: 10px;
  transition: 0.25s ease;
}

.text-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.text-input:focus {
  border-color: rgba(255, 255, 255, 0.35);
  background: rgba(255, 255, 255, 0.12);
  transform: translateY(-1px);
}

.select-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 20px;
}

.option-btn {
  width: 100%;
  min-height: 54px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--text);
  font-size: 16px;
  font-weight: 700;
  padding: 14px 16px;
  text-align: center;
  transition: 0.2s ease;
  appearance: none;
  -webkit-appearance: none;
  outline: none;
  box-shadow: none;
}

.option-btn:active {
  transform: scale(0.98);
}

.option-btn.selected {
  background: rgba(255, 255, 255, 0.18);
  border-color: rgba(255, 255, 255, 0.4);
  box-shadow: 0 8px 24px rgba(255, 255, 255, 0.08);
}

.city-bonus {
  display: block;
  margin-top: 6px;
  font-size: 12px;
  color: var(--muted);
  font-weight: 400;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
